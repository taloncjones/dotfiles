[commit]
    gpgsign = true
# Route every github.com remote in ~/Git/personal through the Git-Personal
# ssh alias automatically (pinned to the personal key in ~/.ssh/config),
# so fresh clones never need a manual `git update-remote`. https URLs keep
# anonymous fetch but push over ssh.
[url "git@Git-Personal:"]
    insteadOf = git@github.com:
    insteadOf = ssh://git@github.com/
    pushInsteadOf = https://github.com/
