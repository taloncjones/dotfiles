      "mcp__plugin_atlassian_atlassian__atlassianUserInfo",
      "mcp__plugin_atlassian_atlassian__getAccessibleAtlassianResources",
      "mcp__plugin_atlassian_atlassian__getJiraIssue",
      "mcp__plugin_atlassian_atlassian__searchJiraIssuesUsingJql",
      "mcp__plugin_atlassian_atlassian__getVisibleJiraProjects",
      "mcp__plugin_atlassian_atlassian__getJiraIssueTypeMetaWithFields",
      "mcp__plugin_atlassian_atlassian__getTransitionsForJiraIssue",
      "mcp__plugin_atlassian_atlassian__transitionJiraIssue"
    ],
    "deny": [],
    "ask": [
      "Bash(rm:*)",
      "mcp__plugin_atlassian_atlassian__createJiraIssue"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/commit_guard.py"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/no_ai_attribution_bash.py"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block_secrets.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect_claude_md.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/emoji_guard.py"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/no_ai_comments.py"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/format_files.py"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_atlassian",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cache_jira_url.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/account_guard.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline.js"
  },
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": false,
    "python-development@claude-code-workflows": true,
    "cicd-automation@claude-code-workflows": true,
    "code-documentation@claude-code-workflows": true,
    "code-refactoring@claude-code-workflows": true,
    "atlassian@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "ecc@ecc": true,
    "superpowers@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ecc": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/ECC.git"
      }
    }
  },
  "mcpServers": {}
}
