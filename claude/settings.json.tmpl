      "Skill(checks)",
      "Skill(co-review)",
      "Skill(codex-plan-review)",
      "Skill(codex-spec-review)",
      "Skill(commit)",
      "Skill(dev-review)",
      "Skill(doc)",
      "Skill(done)",
      "Skill(explain)",
      "Skill(handoff)",
      "Skill(jira)",
      "Skill(kickoff)",
