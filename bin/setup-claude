#!/usr/bin/env bash
# setup-claude - Prepares a project for Claude Code
#
# Adds CLAUDE.md and .claude/ to .git/info/exclude so they stay local.
# Then prompts to run /init or /refresh.

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [ ! -d .git ]; then
    echo -e "${YELLOW}Not a git repository${NC}"
    exit 1
fi

for pattern in "CLAUDE.md" "AGENTS.md" ".claude/"; do
    if ! grep -qxF "$pattern" .git/info/exclude 2>/dev/null; then
        echo "$pattern" >> .git/info/exclude
    fi
done

echo -e "${GREEN}Added to .git/info/exclude${NC}"

if [ -f "CLAUDE.md" ]; then
    echo -e "Run ${GREEN}/refresh${NC} to update CLAUDE.md"
else
    echo -e "Run ${GREEN}/init${NC} to generate CLAUDE.md"
fi
